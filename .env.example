# Copy this file to .env and fill in values for your environment.
# None of these are required for local development — defaults work out of the box.

# MQTT broker (used by edge_controller and stress_test.py)
BROKER_HOST=localhost
BROKER_PORT=1883

# Flask API port
FLASK_PORT=5000

# React dev server proxy target (must match FLASK_PORT)
VITE_API_TARGET=http://localhost:5000
